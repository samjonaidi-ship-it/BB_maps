# BB_Maps Configuration

# Server
PORT=8080
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=production

# CORS (comma-separated origins, or * for all)
CORS_ORIGIN=*

# Rate limiting (requests per minute per IP)
RATE_LIMIT_MAX=200

# Public URL (for style JSON URL resolution)
# Set this to your Railway/production URL
PUBLIC_URL=

# Photon geocoder (internal Docker network address)
PHOTON_URL=http://photon:2322

# Default geocoding bounding box (Bay Area)
GEOCODE_BBOX=-122.52,36.95,-121.73,37.82

# Data directories
TILES_DIR=data/tiles
STYLES_DIR=data/styles
FONTS_DIR=data/fonts
SPRITES_DIR=data/sprites
VERSION_FILE=data/version.json

# Admin API key (for version updates + counter resets)
ADMIN_API_KEY=

# Esri satellite settings
ESRI_MAX_ZOOM=19
